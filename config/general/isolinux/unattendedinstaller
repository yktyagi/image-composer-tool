ISO_ROOT=/cdrom
CONFIG_ROOT="$ISO_ROOT/config"
CACHE_REPO="$ISO_ROOT/cache-repo"
LOG_FILE="/tmp/unattended-installer.log"
LOCK_DIR="/tmp/unattended-installer.lock"

# Prevent multiple unattended installer instances from running at the same time.
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    echo "Another unattended installer instance is already running. See the installer log at $LOG_FILE and then exit."
    exit 0
fi

# Capture the full unattended run output for post-boot diagnostics.
# tee keeps output visible on the console while persisting it to a file.
exec 3>&1 4>&2
exec > >(tee -a "$LOG_FILE") 2>&1
echo "=== unattended installer start $(date -Iseconds) ==="
echo "Logging to $LOG_FILE"

# Mounting the ISO root for the installer.
mkdir -p "$ISO_ROOT"
LABELS=(ICT_CDROM)

function mount_iso_root {
    local label
    for label in "${LABELS[@]}"; do
        if mount -L "$label" -o ro "$ISO_ROOT" 2>/dev/null; then
            echo "Mounted ISO root using label $label"
            return 0
        fi
    done

    if mount -t iso9660 -o ro /dev/sr0 "$ISO_ROOT" 2>/dev/null; then
        echo "Mounted ISO root using /dev/sr0"
        return 0
    fi

    return 1
}

function retry {
    local retry=0
    local limit=10
    local sleep_seconds=15
    while [[ $retry -lt $limit ]]
    do
        eval "$@" && break
        echo "$@" Retrying...
        retry=$((retry + 1))
        sleep $sleep_seconds
    done
}

if grep -qs "$ISO_ROOT" /proc/mounts; then
    echo ISO root already mounted
else
    echo Attempt to mount the ISO root
   # It is possible that the partition isn't ready to be mounted when this script
    # is first run. So use a retry loop. There is a race condition here where the
    # partition could be mounted between the first grep and the mount. If this happens
    # the mount will fail and the retry loop would retry the mount repeatedly. This
    # is handled by the 'or' in the retry loop which will grep for the mount point and
    # break out of the loop if it is found.
    retry "mount_iso_root || grep -qs \"$ISO_ROOT\" /proc/mounts"
fi

TEMPLATE_DUMP_YAML=$(find "$CONFIG_ROOT" -type f -name "template-dump.yaml" | head -n 1)
if [[ -n "$TEMPLATE_DUMP_YAML" ]]; then
    echo "find template-dump.yaml at $TEMPLATE_DUMP_YAML"
else
    echo "template-dump.yaml not found in $CONFIG_ROOT"
    /bin/bash
    exit 1
fi

# Turn off echoing while the installer runs to stop sensitive data from rendering in the TTY session.
stty -echo

# Disable kernel messages on the current terminal
dmesg -D

if live-installer --config "$TEMPLATE_DUMP_YAML" --repo "$CACHE_REPO"; then
    installerExitCode=0
else
    installerExitCode=$?
fi

# Consume any buffered stdin to prevent it from being passed to any future programs,
# as it may contain sensitive data
while read -t 1 -n 10000
do
    echo ""
done

# Turn back on echoing input so the TTY session is usable for the user.
stty echo

# Enable kernel messages
dmesg -E

if [[ $installerExitCode -eq 0 ]]; then
    echo "Unattended install completed successfully"
    reboot
else
    echo "Unattended install failed with exit code $installerExitCode"
    echo "Installer log is available at $LOG_FILE"
    rmdir "$LOCK_DIR" 2>/dev/null || true
    # Restore direct console output before launching an interactive shell.
    exec 1>&3 2>&4
    exec /bin/bash -i
fi