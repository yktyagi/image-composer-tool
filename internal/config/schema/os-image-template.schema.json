{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "os-image-template.schema.json",
  "title": "OS Image Template Schemas",
  "description": "Schemas for validating both user-provided templates and fully merged templates.",
  "$defs": {
    "Image": {
      "type": "object",
      "description": "Image metadata and versioning",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the image template",
          "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9\\-_]*[a-zA-Z0-9])?$"
        },
        "version": {
          "type": "string",
          "description": "Version of the image template",
          "pattern": "^[0-9]+(\\.([0-9]+|[0-9]*[a-zA-Z-][0-9a-zA-Z-]*)){0,2}(\\+[0-9a-zA-Z-]+(\\.[0-9a-zA-Z-]+)*)?$"
        }
      },
      "required": ["name", "version"],
      "additionalProperties": false
    },
    "Target": {
      "type": "object",
      "description": "Target platform and system configuration",
      "properties": {
        "os": {
          "type": "string",
          "description": "Target operating system",
          "enum": ["azure-linux", "edge-microvisor-toolkit", "wind-river-elxr", "ubuntu", "redhat-compatible-distro", "debian"]
        },
        "dist": {
          "type": "string",
          "description": "Target distribution version"
        },
        "arch": {
          "type": "string",
          "description": "Target architecture",
          "enum": ["x86_64", "aarch64", "armv7hl"]
        },
        "imageType": {
          "type": "string",
          "description": "Type of image to build",
          "enum": ["raw", "img", "iso", "wsl2"]
        }
      },
      "required": ["os", "dist", "arch", "imageType"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "os": { "const": "azure-linux" } } },
          "then": { "properties": { "dist": { "enum": ["azl3"] } } }
        },
        {
          "if": { "properties": { "os": { "const": "edge-microvisor-toolkit" } } },
          "then": { "properties": { "dist": { "enum": ["emt3"] } } }
        },
        {
          "if": { "properties": { "os": { "const": "wind-river-elxr" } } },
          "then": { "properties": { "dist": { "enum": ["elxr12", "elxr13"] } } }
        },
        {
          "if": { "properties": { "os": { "const": "debian" } } },
          "then": { "properties": { "dist": { "enum": ["debian13"] } } }
        },
        {
          "if": { "properties": { "os": { "const": "ubuntu" } } },
          "then": { "properties": { "dist": { "enum": ["ubuntu24", "ubuntu26"] } } }
        }
      ]
    },
    "Disk": {
      "type": "object",
      "description": "Disk configuration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the disk configuration"
        },
        "path": {
          "type": "string",
          "description": "Path to the disk device"
        },
        "selectionPolicy": {
          "type": "object",
          "description": "Policy-based disk selection used when path is empty",
          "properties": {
            "strategy": {
              "type": "string",
              "description": "Disk selection strategy",
              "enum": ["first", "largest", "fastest"]
            },
            "excludeRemovable": {
              "type": "boolean",
              "description": "Exclude removable or externally attached disks from selection using RM, transport, hotplug, udev, and sysfs heuristics",
              "default": true
            },
            "requireEmpty": {
             "type": "boolean",
             "description": "Require the selected disk to have no existing partitions before installation. This check does not detect raw or unpartitioned data already on the disk. When false, installation may overwrite existing data on the selected disk.",
             "default": true
            }
          },
          "additionalProperties": false
        },
        "artifacts": {
          "type": "array",
          "description": "Output artifacts configuration",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Output format type",
                "enum": ["raw", "qcow2", "vhd", "vhdx", "vmdk", "vdi", "tar"]
              },
              "compression": {
                "type": "string",
                "description": "Compression format (optional)",
                "enum": ["gz", "gzip", "xz", "zstd", "bz2"]
              }
            },
            "required": ["type"],
            "additionalProperties": false
          }
        },
        "size": {
          "type": "string",
          "description": "Size of the disk (e.g., '4GiB', '8GB')"
        },
        "partitionTableType": {
          "type": "string",
          "description": "Partition table type",
          "enum": ["gpt", "mbr"]
        },
        "partitions": {
          "type": "array",
          "description": "Partition layout",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Partition identifier" },
              "index": {"type": "integer", "description": "Partition index"},
              "name": { "type": "string", "description": "Partition name/label" },
              "type": { "type": "string", "description": "Partition type" },
              "typeUUID": { "type": "string", "description": "Partition type UUID" },
              "fsType": { "type": "string", "description": "Filesystem type" },
              "fsLabel": { "type": "string", "description": "Filesystem label" },
              "start": { "type": "string", "description": "Partition start offset" },
              "end": { "type": "string", "description": "Partition end offset (0 = rest of disk)" },
              "mountPoint": { "type": "string", "description": "Mount point path" },
              "mountOptions": { "type": "string", "description": "Mount options" },
              "flags": { "type": "array", "description": "Partition flags", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "Immutability": {
      "type": "object",
      "description": "Immutability configuration with UEFI Secure Boot support",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether immutability is enabled",
          "default": false
        },
        "secureBootDBKey": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            { "pattern": "^(?:\\$\\{[A-Za-z0-9_]+\\}|(?:[A-Za-z0-9_./-]|\\$\\{[A-Za-z0-9_]+\\})+\\.(?:key|pem))$" },
            { "not": { "pattern": "\\.\\." } }
          ]
        },
        "secureBootDBCrt": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            { "pattern": "^(?:\\$\\{[A-Za-z0-9_]+\\}|(?:[A-Za-z0-9_./-]|\\$\\{[A-Za-z0-9_]+\\})+\\.(?:crt|pem))$" },
            { "not": { "pattern": "\\.\\." } }
          ]
        },
        "secureBootDBCer": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            { "pattern": "^(?:\\$\\{[A-Za-z0-9_]+\\}|(?:[A-Za-z0-9_./-]|\\$\\{[A-Za-z0-9_]+\\})+\\.cer)$" },
            { "not": { "pattern": "\\.\\." } }
          ]
        }
      },
      "required": ["enabled"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "anyOf": [
              { "required": ["secureBootDBKey"] },
              { "required": ["secureBootDBCrt"] },
              { "required": ["secureBootDBCer"] }
            ]
          },
          "then": {
            "required": ["secureBootDBKey", "secureBootDBCrt", "secureBootDBCer"],
            "properties": {
              "enabled": { "const": true }
            }
          }
        }
      ]
    },
    "Users": {
      "type": "array",
      "description": "User configurations",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Username for the user account" },
          "password": { "type": "string", "description": "Plain text password (discouraged for security)" },
          "hash_algo": { "type": "string", "description": "Hash algorithm (e.g., sha512, bcrypt)" },
          "passwordMaxAge": { "type": "integer", "description": "Maximum password age in days" },
          "startupScript": { "type": "string", "description": "Shell/script to run on login" },
          "groups": { "type": "array", "items": { "type": "string" }, "description": "Additional groups" },
          "sudo": { "type": "boolean", "description": "Grant sudo permissions" },
          "home": { "type": "string", "description": "Home directory path" },
          "shell": { "type": "string", "description": "Login shell" }
        },
        "required": ["name"],
        "additionalProperties": false
      }
    },
    "Initramfs": {
      "type": "object",
      "description": "Initramfs configuration",
      "properties": {
        "template": {
          "type": "string",
          "description": "Path to the initramfs template file"
        }
      },
      "required": ["template"],
      "additionalProperties": false
    },
    "Bootloader": {
      "type": "object",
      "description": "Bootloader configuration",
      "properties": {
        "bootType": { "type": "string", "enum": ["efi", "legacy"] },
        "provider": { "type": "string", "enum": ["grub", "grub2", "systemd-boot"] }
      },
      "additionalProperties": false
    },
    "NetworkInterface": {
      "type": "object",
      "description": "Network interface configuration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Interface name (e.g., enp1s0, ens3)",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,14}$"
        },
        "dhcp4": {
          "type": "boolean",
          "description": "Enable DHCPv4"
        },
        "dhcp6": {
          "type": "boolean",
          "description": "Enable DHCPv6"
        },
        "addresses": {
          "type": "array",
          "description": "Static IP addresses in CIDR notation (e.g., 192.168.1.10/24). Omit or use an empty list when DHCP is enabled; static addresses must not be set together with DHCP on the same interface.",
          "items": {
            "type": "string",
            "oneOf": [
              { "format": "ipv4-cidr" },
              { "format": "ipv6-cidr" }
            ]
          }
        },
        "routes": {
          "type": "array",
          "description": "Static routes (use 'default' as destination for default gateway)",
          "items": {
            "type": "object",
            "properties": {
              "to": {
                "type": "string",
                "description": "Route destination (e.g., 'default', '10.0.0.0/8')",
                "oneOf": [
                  { "const": "default" },
                  { "format": "ipv4-cidr" },
                  { "format": "ipv6-cidr" }
                ]
              },
              "via": {
                "type": "string",
                "description": "Gateway address (e.g., '10.0.0.1')",
                "oneOf": [
                  { "format": "ipv4" },
                  { "format": "ipv6" }
                ]
              }
            },
            "required": ["to", "via"],
            "additionalProperties": false
          }
        },
        "nameservers": {
          "type": "array",
          "description": "DNS server addresses",
          "items": {
            "type": "string",
            "oneOf": [
              { "format": "ipv4" },
              { "format": "ipv6" }
            ]
          }
        }
      },
      "required": ["name"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "anyOf": [
              {
                "required": ["dhcp4"],
                "properties": { "dhcp4": { "const": true } }
              },
              {
                "required": ["dhcp6"],
                "properties": { "dhcp6": { "const": true } }
              }
            ]
          },
          "then": {
            "properties": {
              "addresses": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "NetworkConfig": {
      "type": "object",
      "description": "Network configuration for the installed OS",
      "properties": {
        "backend": {
          "type": "string",
          "description": "Network backend to use",
          "enum": ["systemd-networkd", "netplan"]
        },
        "interfaces": {
          "type": "array",
          "description": "List of network interfaces to configure",
          "items": { "$ref": "#/$defs/NetworkInterface" }
        }
      },
      "additionalProperties": false
    },
    "Kernel": {
      "type": "object",
      "description": "Kernel configuration",
      "properties": {
        "name": { "type": "string", "description": "Kernel package name (from defaults)" },
        "version": { "type": "string", "description": "Kernel version" },
        "cmdline": { "type": "string", "description": "Kernel command line parameters" },
        "enableExtraModules": { "type": "string", "description": "Additional kernel modules to be loaded" },
        "uki": { "type": "boolean", "description": "Enable Unified Kernel Image (from defaults)" },
        "packages": {
          "type": "array",
          "description": "Additional kernel packages",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "SystemConfig": {
      "type": "object",
      "description": "System configuration object",
      "properties": {
        "name": { "type": "string", "description": "Name of the system configuration" },
        "description": { "type": "string", "description": "Description of the system configuration" },
        "initramfs": { "$ref": "#/$defs/Initramfs" },
        "hostname": {
          "type": "string",
          "description": "Hostname of the system"},
        "immutability": { "$ref": "#/$defs/Immutability" },
        "users": { "$ref": "#/$defs/Users" },
        "bootloader": { "$ref": "#/$defs/Bootloader" },
        "network": { "$ref": "#/$defs/NetworkConfig" },
        "packages": {
          "type": "array",
          "description": "List of packages to include in the system. Supports simple glob-style patterns on package names, such as wayland* or libva-?[0-9]. Wildcards are limited to *, ?, and bracket ranges (e.g. [0-9]); patterns must match the allowed character set in this schema and are applied only to package names (versioned globs or comparison operators like pkg>=1.2 are not supported). Invalid patterns will cause template validation to fail.",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9+_.:~*?\\[\\]-]*$" },
          "uniqueItems": true
        },
        "additionalFiles": {
          "type": "array",
          "description": "Additional files to include in the system",
          "items": { "type": "object", "additionalProperties": true }
        },
        "configurations": {
          "type": "array",
          "description": "Array of shell commands to execute during system configuration",
          "items": { "type": "object", "additionalProperties": true }
        },
        "kernel": { "$ref": "#/$defs/Kernel" }
      },
      "additionalProperties": false
    },
    "Metadata": {
      "type": "object",
      "description": "AI-searchable metadata for template discovery",
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of the template"
        },
        "use_cases": {
          "type": "array",
          "description": "List of use cases this template is designed for",
          "items": { "type": "string" }
        },
        "keywords": {
          "type": "array",
          "description": "Keywords for template discovery and search",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "Baseline": {
      "type": "object",
      "description": "Baseline image mode selector. Default mode is 'create' (build from scratch). 'overlay' layers packages onto an existing baseline image.",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Baseline assembly mode",
          "enum": ["create", "overlay"],
          "default": "create"
        },
        "source": { "$ref": "#/$defs/BaselineSource" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "overlay" } }, "required": ["mode"] },
          "then": { "required": ["source"] }
        },
        {
          "if": {
            "anyOf": [
              { "properties": { "mode": { "const": "create" } }, "required": ["mode"] },
              { "not": { "required": ["mode"] } }
            ]
          },
          "then": { "not": { "required": ["source"] } }
        }
      ]
    },
    "BaselineSource": {
      "type": "object",
      "description": "Baseline source. v1 supports a local RAW disk image, referenced by a local path or an https URL. Exactly one of 'path' or 'url' must be set.",
      "properties": {
        "path": {
          "type": "string",
          "description": "Local filesystem path to the baseline RAW disk image (no URI scheme; use 'url' for remote images)",
          "minLength": 1,
          "not": { "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:" }
        },
        "url": {
          "type": "string",
          "description": "https URL of the baseline RAW disk image; downloaded over TLS before the overlay runs (plain http is rejected)",
          "minLength": 1,
          "pattern": "^https://[^/?#]"
        },
        "format": {
          "type": "string",
          "description": "Baseline image format",
          "enum": ["raw"],
          "default": "raw"
        }
      },
      "additionalProperties": false
    },
    "OverlayPolicy": {
      "type": "object",
      "description": "Policy controls for overlay-mode preflight and install. allowRemoval is intentionally absent: removals are never permitted in v1.",
      "properties": {
        "packageOperation": {
          "type": "string",
          "description": "Permitted package operation set",
          "enum": ["additive-only"],
          "default": "additive-only"
        },
        "conflictPolicy": {
          "type": "string",
          "description": "How to handle package conflicts detected during preflight",
          "enum": ["fail", "allow-explicit"],
          "default": "fail"
        },
        "kernelCmdline": {
          "type": "string",
          "description": "Optional kernel command-line override applied to the overlaid image"
        }
      },
      "additionalProperties": false
    },
    "PackageRepository": {
      "type": "object",
      "description": "Additional package repository configuration",
      "properties": {
        "codename": {
          "type": "string",
          "description": "Repository identifier/codename",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "description": "Repository base URL",
          "oneOf": [
            { "format": "uri" },
            { "const": "<URL>", "description": "Placeholder used in example templates" }
          ]
        },
        "path": {
          "type": "string",
          "description": "Local directory path for file-based repositories",
          "pattern": "^/"
        },
        "packages": {
          "type": "array",
          "description": "Files to populate the local repository path: each entry is an https:// URL (downloaded), a local directory (all .deb/.rpm files inside are copied), or a local file path (copied/extracted). Supports .deb, .rpm, .tar, .tar.gz, and .zip archives.",
          "items": {
            "type": "string",
            "anyOf": [
              { "pattern": "^https://", "description": "HTTPS URL to download" },
              { "pattern": "^/", "description": "Absolute local file path" },
              { "pattern": "^\\./|\\.\\./", "description": "Relative local file path" }
            ]
          },
          "minItems": 1
        },
        "insecureSkipVerify": {
          "type": "boolean",
          "description": "Skip TLS certificate verification for onlineFiles downloads (insecure, use with caution for untrusted or self-signed certificates)",
          "default": false
        },
        "pkey": {
          "type": "string",
          "description": "Public GPG key URL for package verification or [trusted=yes] to skip verification",
          "oneOf": [
            {
              "pattern": "^(https?|file)://",
              "description": "URL to GPG key file (must start with http://, https://, or file://)"
            },
            {
              "pattern": "^/",
              "description": "Absolute local file path to GPG key file"
            },
            {
              "const": "[trusted=yes]",
              "description": "Special value to mark repository as trusted and skip GPG verification"
            },
            {
              "const": "<PUBLIC_KEY_URL>",
              "description": "Placeholder value for template examples"
            }
          ]
        },
        "pkeys": {
          "type": "array",
          "description": "Multiple public GPG key URLs for package verification (alternative to pkey)",
          "items": {
            "type": "string",
            "oneOf": [
              {
                "pattern": "^(https?|file)://",
                "description": "URL to GPG key file (must start with http://, https://, or file://)"
              },
              {
                "pattern": "^/",
                "description": "Absolute local file path to GPG key file"
              }
            ]
          },
          "minItems": 1
        },
        "component": {
          "type": "string",
          "description": "Repository component (e.g., 'main', 'restricted')",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "description": "Repository priority (higher numbers = higher priority, like apt pinning)",
          "minimum": -9999,
          "maximum": 9999,
          "default": 0
        },
        "allowPackages": {
          "type": "array",
          "description": "Optional: specific packages to include from this repository (package pinning)",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9+_.:~*?\\[\\]-]*$"
          }
        }
      },
      "oneOf": [
        { "required": ["codename", "path"] },
        { "required": ["codename", "url"] },
        { "required": ["codename", "packages"] }
      ],
      "anyOf": [
        { "required": ["pkey"] },
        { "required": ["pkeys"] }
      ],
      "additionalProperties": false
    },

    "FullTemplate": {
      "type": "object",
      "properties": {
        "metadata": { "$ref": "#/$defs/Metadata" },
        "image": { "$ref": "#/$defs/Image" },
        "target": { "$ref": "#/$defs/Target" },
        "baseline": { "$ref": "#/$defs/Baseline" },
        "overlayPolicy": { "$ref": "#/$defs/OverlayPolicy" },
        "disk": { "$ref": "#/$defs/Disk" },
        "systemConfig": { "$ref": "#/$defs/SystemConfig" },
        "sbomPackageMetadata": {
          "type": "array",
          "description": "Optional SBOM package metadata preserved for installer-time SBOM generation",
          "items": { "type": "object", "additionalProperties": true }
        },
        "packageRepositories": {
          "type": "array",
          "description": "Additional package repositories",
          "items": { "$ref": "#/$defs/PackageRepository" }
        }
      },
      "required": ["image", "target", "systemConfig"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "target": {
                "properties": {
                  "imageType": { "const": "wsl2" }
                },
                "required": ["imageType"]
              }
            },
            "required": ["target"]
          },
          "then": {
            "required": ["disk"],
            "properties": {
              "systemConfig": {
                "properties": {
                  "kernel": false
                }
              },
              "disk": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "artifacts": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["tar"]
                        },
                        "compression": {
                          "type": "string",
                          "enum": ["gz"]
                        }
                      },
                      "required": ["type", "compression"],
                      "additionalProperties": false
                    }
                  },
                  "partitionTableType": false,
                  "partitions": false
                },
                "required": ["name", "artifacts"],
                "additionalProperties": false
              }
            }
          },
          "else": {
            "properties": {
              "disk": {
                "properties": {
                  "artifacts": {
                    "items": {
                      "properties": {
                        "type": {
                          "not": { "const": "tar" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "UserTemplate": {
      "type": "object",
      "properties": {
        "extends": {
          "type": "string",
          "description": "Path to a parent template to inherit from. The child template overrides or extends the parent using the standard merge strategies."
        },
        "metadata": { "$ref": "#/$defs/Metadata" },
        "image": { "$ref": "#/$defs/Image" },
        "target": { "$ref": "#/$defs/Target" },
        "baseline": { "$ref": "#/$defs/Baseline" },
        "overlayPolicy": { "$ref": "#/$defs/OverlayPolicy" },
        "disk": { "$ref": "#/$defs/Disk" },
        "systemConfig": { "$ref": "#/$defs/SystemConfig" },
        "sbomPackageMetadata": {
          "type": "array",
          "description": "Optional SBOM package metadata preserved for installer-time SBOM generation",
          "items": { "type": "object", "additionalProperties": true }
        },
        "packageRepositories": {
          "type": "array",
          "description": "Additional package repositories",
          "items": { "$ref": "#/$defs/PackageRepository" }
        }
      },
      "required": ["image", "target"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "target": {
                "properties": {
                  "imageType": { "const": "wsl2" }
                },
                "required": ["imageType"]
              }
            },
            "required": ["target"]
          },
          "then": {
            "properties": {
              "systemConfig": {
                "properties": {
                  "kernel": false
                }
              },
              "disk": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "artifacts": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["tar"]
                        },
                        "compression": {
                          "type": "string",
                          "enum": ["gz"]
                        }
                      },
                      "required": ["type", "compression"],
                      "additionalProperties": false
                    }
                  },
                  "partitionTableType": false,
                  "partitions": false
                },
                "required": ["name", "artifacts"],
                "additionalProperties": false
              }
            }
          },
          "else": {
            "properties": {
              "disk": {
                "properties": {
                  "artifacts": {
                    "items": {
                      "properties": {
                        "type": {
                          "not": { "const": "tar" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
